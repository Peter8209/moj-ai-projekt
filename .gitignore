# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =========================
# Dependencies
# =========================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================
# Next.js / React build outputs
# =========================
.next/
.next_old_broken/
.next*/
out/
build/
dist/
.turbo/
.vercel/
.swc/
.cache/

# =========================
# Turbopack / Next cache
# =========================
.next/cache/
.next/dev/
.next/server/
.next/static/
.next/types/
.next_old_broken/dev/
.next_old_broken/dev/cache/
.next_old_broken/dev/cache/turbopack/

# =========================
# Testing / coverage
# =========================
coverage/
.nyc_output/

# =========================
# TypeScript
# =========================
*.tsbuildinfo
next-env.d.ts

# =========================
# Environment files
# IMPORTANT: do not commit secrets
# =========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# =========================
# Logs
# =========================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
debug.log

# =========================
# OS / editor files
# =========================
.DS_Store
Thumbs.db
Desktop.ini

.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

.idea/
*.swp
*.swo

# =========================
# Certificates / keys
# =========================
*.pem
*.key
*.crt
*.p12
*.pfx

# =========================
# Local generated exports / documents
# =========================
exports/
generated/
downloads/
tmp/
temp/
uploads/
public/uploads/
public/exports/

*.pptx
*.docx
*.xlsx
*.pdf
*.zip
*.rar
*.7z

# Ak chceš niektoré šablóny PDF/DOCX/PPTX commitovať, daj ich do špeciálneho priečinka:
!templates/
!templates/**/*.pptx
!templates/**/*.docx
!templates/**/*.xlsx
!templates/**/*.pdf

# =========================
# Large media files
# =========================
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.mp3
*.wav

# =========================
# Supabase / local tools
# =========================
.supabase/
supabase/.branches/
supabase/.temp/

# =========================
# Package manager stores
# =========================
.pnpm-store/

# =========================
# Local broken / backup folders
# =========================
*_old_broken/
*_backup/
*.bak